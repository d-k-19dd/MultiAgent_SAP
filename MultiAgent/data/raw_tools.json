[
  {
    "tool_id": "Travel/flights_api",
    "tool_name": "flights_api",
    "category": "Travel",
    "domain": "Travel",
    "description": "Search and compare flights for trip planning workflows.",
    "endpoints": [
      {
        "endpoint_id": "Travel/flights_api/search_flights",
        "endpoint_name": "search_flights",
        "description": "Search available flights by airports and departure date. Returns a flight_id to use for itinerary and booking steps.",
        "parameters": [
          {"name": "origin_airport", "type": "string", "required": true, "description": "IATA origin code"},
          {"name": "destination_airport", "type": "string", "required": true, "description": "IATA destination code"},
          {"name": "departure_date", "type": "string", "required": true, "description": "YYYY-MM-DD"}
        ],
        "response": {
          "properties": {
            "flight_id": {"type": "string"},
            "airline": {"type": "string"},
            "departs_at": {"type": "string"},
            "price_usd": {"type": "integer"}
          }
        }
      }
    ]
  },
  {
    "tool_id": "Travel/hotels_api",
    "tool_name": "hotels_api",
    "category": "Travel",
    "domain": "Travel",
    "description": "Find and book hotels using IDs produced by search steps.",
    "endpoints": [
      {
        "endpoint_id": "Travel/hotels_api/search_hotels",
        "endpoint_name": "search_hotels",
        "description": "Search hotels for a city and dates. Returns hotel_id for booking.",
        "parameters": [
          {"name": "city", "type": "string", "required": true},
          {"name": "check_in", "type": "string", "required": true, "description": "YYYY-MM-DD"},
          {"name": "check_out", "type": "string", "required": true, "description": "YYYY-MM-DD"}
        ],
        "response": {
          "properties": {
            "hotel_id": {"type": "string"},
            "name": {"type": "string"},
            "nightly_rate_usd": {"type": "integer"}
          }
        }
      },
      {
        "endpoint_id": "Travel/hotels_api/book_hotel",
        "endpoint_name": "book_hotel",
        "description": "Book a hotel using hotel_id from search_hotels.",
        "parameters": [
          {"name": "hotel_id", "type": "string", "required": true},
          {"name": "check_in", "type": "string", "required": true},
          {"name": "check_out", "type": "string", "required": true},
          {"name": "guest_name", "type": "string", "required": true}
        ],
        "response": {
          "properties": {
            "booking_id": {"type": "string"},
            "confirmation_code": {"type": "string"},
            "status": {"type": "string"}
          }
        }
      }
    ]
  },
  {
    "tool_id": "Travel/itinerary_api",
    "tool_name": "itinerary_api",
    "category": "Travel",
    "domain": "Travel",
    "description": "Attractions and multi-day itinerary planning tied to flight and hotel selections.",
    "endpoints": [
      {
        "endpoint_id": "Travel/itinerary_api/get_attractions",
        "endpoint_name": "get_attractions",
        "description": "List top attractions for a destination city. Returns attraction_id for itinerary building.",
        "parameters": [
          {"name": "city", "type": "string", "required": true},
          {"name": "interests", "type": "string", "required": false, "description": "Comma-separated interests"}
        ],
        "response": {
          "properties": {
            "attraction_id": {"type": "string"},
            "title": {"type": "string"},
            "category": {"type": "string"}
          }
        }
      },
      {
        "endpoint_id": "Travel/itinerary_api/plan_itinerary",
        "endpoint_name": "plan_itinerary",
        "description": "Build a day-by-day itinerary using flight_id, hotel_id, and attraction_id from prior steps.",
        "parameters": [
          {"name": "flight_id", "type": "string", "required": true},
          {"name": "hotel_id", "type": "string", "required": true},
          {"name": "attraction_id", "type": "string", "required": true},
          {"name": "start_date", "type": "string", "required": true}
        ],
        "response": {
          "properties": {
            "itinerary_id": {"type": "string"},
            "days": {"type": "array"},
            "summary": {"type": "string"}
          }
        }
      }
    ]
  },
